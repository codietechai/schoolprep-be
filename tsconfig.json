{
  "compilerOptions": {
    "outDir": "dist",
    "rootDir": ".",
    "module": "NodeNext",
    "target": "ES2020",
    "moduleResolution": "NodeNext",
    "esModuleInterop": true,
    "baseUrl": ".",
    "paths": {
      "admin/*": ["server/admin/*"],
      "common/*": ["server/common/*"],
      "config": ["server/config/index"],
      "constants/*": ["server/constants/*"],
      "helpers/*": ["server/helpers/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
