{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Node",
    "baseUrl": ".",
    "paths": {
      "admin/*": ["server/admin/*"],
      "server/*": ["server/*"],
      "config": ["server/config"],
      "common/*": ["server/common/*"]
    },
    "outDir": "dist",
    "rootDir": ".",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "forceConsistentCasingInFileNames": false
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
